---
// src/components/Partners.astro
const partners = [
    { name: "American Jewish Historical Society", shortName: "AJHS", src: "/logos/AJHS_Logo.png", url: "https://ajhs.org" },
    { name: "Penn Libraries", shortName: "Penn", src: "/logos/Penn_Logo.png", url: "https://library.upenn.edu" },
    { name: "Jewish Theological Seminary", shortName: "JTS", src: "/logos/JTS_Logo.svg", url: "https://www.jtsa.edu" },

    { name: "University of Southampton", shortName: "Southampton", src: "/logos/University_of_Southampton_Logo.png", url: "https://www.southampton.ac.uk/" },
];
---

<section class="bg-neutral-50 py-16 sm:py-20 lg:py-24 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto mb-12 max-w-3xl text-center sm:mb-14">
            <p class="mb-3 text-sm font-semibold uppercase tracking-[0.2em] text-accent-700 dark:text-accent-200">
Partners
            </p>
            <h2 class="text-3xl font-serif font-light text-gray-900 dark:text-gray-100 sm:text-4xl">
                Contributing Institutions
            </h2>
            <p class="mt-4 text-base leading-relaxed text-gray-600 dark:text-gray-300">
                This project is made possible through partnerships with the following libraries, archives,
                and research institutions.
            </p>
        </div>

        <div class="grid grid-cols-2 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 xl:grid-cols-5">
            {partners.map((partner) => (
                    <a
                            href={partner.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`Visit ${partner.name}`}
                            class="group flex min-h-[180px] flex-col items-center justify-between rounded-2xl border border-neutral-200 bg-white p-5 text-center shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 dark:border-gray-700 dark:bg-gray-800"
                    >
                        <div class="flex flex-1 items-center justify-center">
                            <img
                                    src={partner.src}
                                    alt={`${partner.name} logo`}
                                    class="max-h-16 w-auto object-contain sm:max-h-20"
                                    loading="lazy"
                            />
                        </div>

                        <div class="mt-5">
                            <p class="text-sm font-medium text-gray-900 dark:text-gray-100">
                                {partner.name}
                            </p>
                        </div>
                    </a>
            ))}
        </div>
    </div>
</section>