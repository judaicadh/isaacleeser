---
// about.astro
import AboutLeeser, { getHeadings } from './aboutleeser.md';
import TextLayout from "../layouts/TextLayout.astro";

const headings = await getHeadings();
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<TextLayout>
    <section class="bg-[#f7f4ef] dark:bg-gray-900">
        <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8 lg:py-14">
            <header class="mb-10 max-w-5xl">
                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-stone-500 dark:text-gray-400">
                    About
                </p>
                <h1 class="font-serif text-4xl font-light leading-tight text-slate-900 dark:text-gray-100 sm:text-5xl">
                    Isaac Leeser
                </h1>
                <p class="mt-3 font-sans text-base text-stone-600 dark:text-gray-300">
                    By Arthur Kiron
                </p>
                <div class="mt-8 border-b border-stone-300 dark:border-gray-700"></div>
            </header>

            <div class="grid grid-cols-1 gap-10 lg:grid-cols-[220px_minmax(0,820px)] lg:gap-14 xl:grid-cols-[240px_minmax(0,860px)]">
                {tocHeadings.length > 0 && (
                        <aside class="hidden lg:block">
                            <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-4">
                                <nav aria-label="Table of contents">
                                    <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.22em] text-stone-500 dark:text-gray-400">
                                        On this page
                                    </h2>

                                    <ol class="space-y-1.5 border-l border-stone-300 pl-4 dark:border-gray-700">
                                        {tocHeadings.map((heading) => (
                                                <li class={heading.depth === 3 ? "ml-3" : ""}>
                                                    <a
                                                            href={`#${heading.slug}`}
                                                            class={`block py-0.5 text-sm leading-6 transition-colors hover:text-accent-700 dark:hover:text-accent-200 ${
                                                                heading.depth === 2
                                                                    ? "font-medium text-slate-700 dark:text-gray-200"
                                                                    : "text-slate-500 dark:text-gray-400"
                                                            }`}
                                                    >
                                                        {heading.text}
                                                    </a>
                                                </li>
                                        ))}
                                    </ol>
                                </nav>
                            </div>
                        </aside>
                )}

                <article
                        class="max-w-none font-sans text-stone-700 dark:text-gray-200
         [&_p]:my-5
         [&_p]:leading-8
         [&_h2]:mt-16
         [&_h2]:mb-6
         [&_h2]:border-b
         [&_h2]:border-stone-300
         [&_h2]:pb-2
         [&_h2]:font-serif
         [&_h2]:text-3xl
         [&_h2]:font-bold
         [&_h2]:text-slate-900
         dark:[&_h2]:border-gray-700
         dark:[&_h2]:text-gray-100
         [&_h3]:mt-10
         [&_h3]:mb-4
         [&_h3]:font-serif
         [&_h3]:text-2xl
         [&_h3]:font-bold
         [&_h3]:text-slate-900
         dark:[&_h3]:text-gray-100
         [&_a]:text-accent-700
         [&_a]:underline
         [&_a]:underline-offset-4
         hover:[&_a]:text-accent-800
         dark:[&_a]:text-accent-200
         dark:hover:[&_a]:text-accent-100
         [&_ul]:my-6
         [&_ul]:list-disc
         [&_ul]:pl-8
         [&_ul]:space-y-3
         [&_ol]:my-6
         [&_ol]:list-decimal
         [&_ol]:pl-8
         [&_li]:leading-7
         [&_li]:pl-1
         [&_li::marker]:text-stone-500
         [&_strong]:font-semibold
         [&_strong]:text-slate-900
         dark:[&_strong]:text-gray-100"
                >
                    <AboutLeeser />
                </article>
            </div>
        </div>
    </section>
</TextLayout>